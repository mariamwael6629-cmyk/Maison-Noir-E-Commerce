# Copy this file to .env and adjust values for your environment.

# SQLAlchemy database URL. Defaults to a local SQLite file if unset.
# Examples:
#   sqlite:///./maison_noir.db
#   postgresql+psycopg2://user:password@localhost:5432/maison_noir
DATABASE_URL=sqlite:///./maison_noir.db

# Secret used to sign JWT access tokens. Generate your own, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-string

# JWT settings
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Comma-separated list of origins allowed to call this API (your frontend URL(s)).
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000,http://127.0.0.1:3000

# Default admin account created by the seed script.
ADMIN_EMAIL=admin@maisonnoir.com
ADMIN_PASSWORD=admin123
